# =============== Unity generated ===============
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/

# Asset meta data should be tracked
!/[Aa]ssets/**/*.meta

# Auto-generated Visual Studio / Rider files
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb

# OS files
.DS_Store
Thumbs.db

# Builds
*.apk
*.aab
*.unitypackage

# Packages
Packages/packages-lock.json

# Crash reports
sysinfo.txt

# Shader compiler intermediate files
*.shader~ 

# Memory snapshots (Large)
*.memsnap

# JetBrains Rider
.idea/

# Packages: keep manifests, ignore package caches
!Packages/manifest.json
!Packages/packages-lock.json
Packages/*/
Packages/*/node_modules/

# ProjectSettings: track all project settings (important for team projects)
!ProjectSettings/**
# optional: ignore local editor user settings
ProjectSettings/EditorUserSettings.asset

# Packed Addressable asset data (optional - track if you want)
# /Assets/AddressableAssetsData/*

# Exclude local Unity cache (optional)
# /Library/com.unity.collab-proxy/

# End
